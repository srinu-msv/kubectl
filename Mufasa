def get_weather(city):
    return f"Weather information for {city}"

def ask_claude(user_question):
    user_question_lower = user_question.lower()

    if "weather" in user_question_lower or "umbrella" in user_question_lower:
        words = user_question.replace("?", "").split()

        city = None

        for i, word in enumerate(words):
            if word.lower() in ["in", "at"] and i + 1 < len(words):
                city = words[i + 1]
                break

        if not city:
            city = "your city"

        weather = get_weather(city)
        return f"{weather}. You can plan accordingly!"

    else:
        return "This question is not related to weather."

print(ask_claude("Should I carry an umbrella in Jaipur today?"))
print(ask_claude("What is the capital of Rajasthan?"))



